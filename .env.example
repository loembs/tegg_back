# ============================================
# Platforme Tegg - Environment Variables Example
# Copy this file to .env and customize values
# ============================================

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# Database Configuration
DB_HOST=postgres
DB_NAME=tegg_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=TeggSecretKeyForJWTTokenGeneration2024MustBeLongEnough
JWT_EXPIRATION_MS=86400000

# CORS Configuration
CORS_ORIGINS=*

# Server Configuration
SERVER_PORT=8080

# File Upload
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB
